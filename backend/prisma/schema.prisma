generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

enum LeaveType {
  PAID
  SICK
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                     String       @id @default(cuid())
  employeeId             String       @unique
  name                   String?
  email                  String?      @unique
  passwordHash           String?
  role                   Role         @default(EMPLOYEE)
  department             String?
  jobTitle               String?
  phone                  String?
  address                String?
  profilePicture         String?
  isEmailVerified        Boolean      @default(false)
  emailVerificationToken String?      @unique
  passwordResetToken     String?      @unique
  passwordResetExpires   DateTime?
  documents              Document[]
  attendances            Attendance[]
  leaves                 Leave[]      @relation("LeavesRequested")
  reviewedLeaves         Leave[]      @relation("LeavesReviewed")
  payrolls               Payroll[]
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@index([role])
}

model Document {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName   String
  fileUrl    String
  fileType   String
  uploadedAt DateTime @default(now())

  @@index([userId])
}

model Attendance {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime          @db.Date
  status    AttendanceStatus
  checkIn   DateTime?
  checkOut  DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([userId, date])
  @@index([date])
}

model Leave {
  id           String      @id @default(cuid())
  userId       String
  requester    User        @relation("LeavesRequested", fields: [userId], references: [id], onDelete: Cascade)
  type         LeaveType
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  remarks      String?
  status       LeaveStatus @default(PENDING)
  adminComment String?
  reviewedById String?
  reviewer     User?       @relation("LeavesReviewed", fields: [reviewedById], references: [id], onDelete: Cascade)
  reviewedAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId, status])
}

model Payroll {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  baseSalary    Decimal  @db.Decimal(12, 2)
  allowances    Decimal  @default(0) @db.Decimal(12, 2)
  deductions    Decimal  @default(0) @db.Decimal(12, 2)
  netSalary     Decimal  @db.Decimal(12, 2)
  effectiveDate DateTime @db.Date
  createdAt     DateTime @default(now())

  @@index([userId, effectiveDate])
}
